---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'imgcomp',
  description = 'Compress images locally in your browser with a mobile-first workflow, clipboard support, and optional format conversion.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f1f5f9" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
