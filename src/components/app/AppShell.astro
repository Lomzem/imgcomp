<div class="mx-auto flex min-h-screen max-w-5xl flex-col px-4 pb-20 pt-6 sm:px-6 lg:px-8">
  <header class="flex items-center justify-between" style="animation: rise 0.4s ease-out both">
    <div class="select-none font-mono text-sm font-semibold tracking-tight">
      <span class="text-ember">img</span><span class="text-ink-3">comp</span>
    </div>
    <div class="font-mono text-[10px] uppercase tracking-[0.15em] text-ink-3/50">
      local · private · exif stripped
    </div>
  </header>

  <main id="compressor-app" data-app-root class="mt-6 grid gap-4 lg:grid-cols-[20rem_1fr]">
    <div
      data-region="intake"
      class="order-1 lg:col-start-1"
      style="animation: rise 0.4s ease-out 0.05s both"
    >
    </div>
    <div
      data-region="selected"
      class="order-2 lg:col-start-2 lg:row-start-1 lg:row-span-3"
      style="animation: rise 0.4s ease-out 0.1s both"
    >
    </div>
    <div
      data-region="settings"
      class="order-3 lg:col-start-1"
      style="animation: rise 0.4s ease-out 0.15s both"
    >
    </div>
    <div
      data-region="queue"
      class="order-4 lg:col-start-1"
      style="animation: rise 0.4s ease-out 0.2s both"
    >
    </div>
  </main>
</div>
